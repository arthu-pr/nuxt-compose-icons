{
  "entryPoints": [
    "./packages/nuxt/src/module.ts",
    "./packages/nuxt/src/runtime/types/index.ts",
    "./packages/nuxt/src/runtime/composables/use-compose-icon.ts",
    "./packages/nuxt/src/runtime/composables/use-compose-icons-registry.ts",
    "./packages/nuxt/src/runtime/utils/icon-theming.ts"
  ],
  "name": "nuxt-compose-icons",

  "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
  "out": "./docs/api", // This is where the documentation will be written
  "tsconfig": "./tsconfig.typedoc.json", // Reference the root tsconfig to include docs/
  "docsRoot": "./docs",
  "theme": "markdown",
  "commentStyle": "jsdoc",

  "exclude": [
    "**/*/node_modules/**/*",
    "node_modules",
    "**/dist/**",
    "**/test/**",
    "**/tests/**",
    "**/__tests__/**",
    "**/.pnpm/**"
  ],
  "indexFormat": "table",
  "useCodeBlocks": true,
  "packageOptions": {
    "name": "nuxt-compose-icons",
    "excludeNotExported": true,
    "readme": "README.md"
  },
  "disableSources": false,
  "sidebar": {
    "autoConfiguration": true,
    "format": "vitepress",
    "pretty": true,
    "collapsed": false
  },
  "jsDocCompatibility": {
    "exampleTag": true,
    "defaultTag": true,
    "inheritDocTag": true,
    "ignoreUnescapedBraces": true
  }
}
